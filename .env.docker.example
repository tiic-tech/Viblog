# ============================================
# Viblog Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# All keys are optional except where noted
# ============================================

# ============================================
# Database (Auto-configured in Docker)
# ============================================
DATABASE_URL=postgresql://viblog:viblog@db:5432/viblog

# ============================================
# LLM Configuration
# ============================================
# Choose one or more providers - you only need one
# These are YOUR API keys for your personal use

# OpenAI (Recommended)
OPENAI_API_KEY=sk-...

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# MiniMax
MINIMAX_API_KEY=...

# Moonshot (Kimi)
MOONSHOT_API_KEY=sk-...

# ZhiPu AI
ZHIPU_API_KEY=...

# Google Gemini
GEMINI_API_KEY=...

# OpenRouter (Multi-provider)
OPENROUTER_API_KEY=sk-or-...

# ============================================
# MCP Server
# ============================================
MCP_API_URL=http://localhost:3000/api

# ============================================
# Auth Configuration (Optional)
# ============================================
# Set to true if deploying to personal domain
# Enables login and public profile features
ENABLE_AUTH=false

# Required if ENABLE_AUTH=true
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=

# ============================================
# Optional Features (Future)
# ============================================
# Apache AGE for knowledge graph
ENABLE_APACHE_AGE=false

# TimescaleDB for time-series analytics
ENABLE_TIMESCALEDB=false

# ============================================
# Development Only
# ============================================
# Uncomment for local development without Docker
# DATABASE_URL=postgresql://viblog:viblog@localhost:5432/viblog